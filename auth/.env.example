NODE_ENV=development
PORT=4000

# Public issuer URL of this auth service
ISSUER=http://localhost:4000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=auth
DB_PASSWORD=auth
DB_NAME=auth

# Session
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=604800

# Access/ID token lifetimes
ACCESS_TOKEN_TTL_SECONDS=900
ID_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# JWK used to sign JWT (generate with: npm run keys:generate)
# Example: {"kty":"RSA",...,"d":"..."}
AUTH_PRIVATE_JWK_JSON=

# Users service integration
USERS_SERVICE_URL=http://localhost:4001
USERS_INTERNAL_TOKEN=users-internal-token

# Initial seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin

SEED_CLIENT_ID=demo-client
SEED_CLIENT_SECRET=demo-secret
SEED_CLIENT_REDIRECT_URIS=http://localhost:5173/callback
SEED_CLIENT_SCOPES=openid,profile,roles

