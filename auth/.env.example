NODE_ENV=development
SERVER_TYPE=DEV
PORT=4000

ISSUER=http://localhost:4000

DB_HOST=localhost
DB_PORT=5432
DB_USER=auth
DB_PASSWORD=auth
DB_NAME=auth

# SSO session (cookie) - "логин один раз, доступ везде"
SESSION_COOKIE_NAME=auth_session
SESSION_TTL_SECONDS=604800
# Для подписи cookie (опционально, по умолчанию AUTH_INTERNAL_TOKEN)
# SESSION_COOKIE_SECRET=

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# npm run keys:generate
# Example: {"kty":"RSA",...,"d":"..."}
AUTH_PRIVATE_JWK_JSON=

USERS_SERVICE_URL=http://localhost:4001
USERS_INTERNAL_TOKEN=users-internal-token
