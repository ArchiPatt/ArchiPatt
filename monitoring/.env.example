PORT=4010
NODE_ENV=development

# PostgreSQL (отдельная БД в том же инстансе, что и остальные сервисы)
# Создайте БД один раз: psql -c "CREATE DATABASE monitoring;"
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=monitoring

# Максимум строк в таблице events (старые удаляются при превышении)
MONITORING_MAX_EVENTS=100000
